# Copy to .env and fill in real values. Never commit .env.

# ──────────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────────

# Bearer token clients must send as `Authorization: Bearer <token>`.
# Generate one with:  openssl rand -hex 32
FRPCMGR_API_TOKEN=change-me-to-a-long-random-string


# ──────────────────────────────────────────────────────────────────
# Runtime options (all optional)
# ──────────────────────────────────────────────────────────────────

# FRPCMGR_HTTP_PORT=18080
# FRPCMGR_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# FRPCMGR_LOG_LEVEL=info
# FRPCMGR_DOCS_ENABLED=true     # set to false to hide /api/docs in production
# TZ=Asia/Shanghai


# ──────────────────────────────────────────────────────────────────
# Standalone compose only (docker-compose.standalone.yml)
# ──────────────────────────────────────────────────────────────────

# Image tag from ghcr.io. Use "latest" to track main, "vX.Y.Z" to pin.
# FRPCMGR_IMAGE_TAG=latest

# Where to mount the daemon's persistent data on the host.
# FRPCMGR_DATA_DIR=./data

# Container memory limit.
# FRPCMGR_MEMORY_LIMIT=512M

# Set to "true" to opt-in to Watchtower auto-updates.
# FRPCMGR_AUTOUPDATE=false


# ──────────────────────────────────────────────────────────────────
# Local build only (docker-compose.yml)
# ──────────────────────────────────────────────────────────────────

# Build metadata stamped into binaries.
VERSION=dev
# BUILD_DATE is set automatically by `make docker` (date -u +%Y-%m-%d).
